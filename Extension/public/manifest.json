{
  "manifest_version": 3,
  "name": "KeyNova",
  "version": "2.0.0",
  "description": "Professional password vault — AES-256 encrypted, cloud synced, smart autofill.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/firebase-config.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": ["storage"]
}
